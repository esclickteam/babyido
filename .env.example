# MongoDB Atlas — database: babydo
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/babydo

# NextAuth — generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://babyido.com

# Google OAuth (optional)
AUTH_GOOGLE_ID=
# Resend — vaccination email reminders (optional)
RESEND_API_KEY=
EMAIL_FROM=BabyIdo <noreply@babyido.com>

# Cron — protect /api/cron/* routes
CRON_SECRET=
